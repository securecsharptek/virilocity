# ─────────────────────────────────────────────────────────────────────────────
# Virilocity V16.4 Vercel Multicloud — Environment Variables
# Copy to .env.local for development. Never commit real values.
# CloudOneSoftware LLC · Dr. Kenneth Melie, PhD
# ─────────────────────────────────────────────────────────────────────────────

# ── Platform ──────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://app.virilocity.io
CORS_ORIGIN=https://app.virilocity.io,http://localhost:3000

# ── JWT Auth (RS256 — ASVS V4.1.1) ──────────────────────────────────────────
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_EXPIRY=3600

# ── Neon Postgres (multicloud serverless DB) ──────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/virilocity?sslmode=require

# ── Upstash Redis (Vercel Edge compatible rate limiting) ──────────────────────
# TEVV F-03: In-memory fallback activates automatically if these are absent
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Anthropic AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Stripe Billing ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# TEVV F-02: Webhook secret for stripe.webhooks.constructEvent() replay guard
STRIPE_WEBHOOK_SECRET=whsec_...

# ── HubSpot ───────────────────────────────────────────────────────────────────
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret
# TEVV F-02: Used in X-HubSpot-Signature-V3 HMAC + timestamp replay guard
HUBSPOT_WEBHOOK_SECRET=your-hubspot-webhook-secret

# ── Microsoft Entra ID (Azure AD) ─────────────────────────────────────────────
ENTRA_TENANT_ID=your-azure-ad-tenant-id
ENTRA_CLIENT_ID=your-app-registration-client-id
# Stored in Azure Key Vault — reference via secret name, not value directly
ENTRA_CLIENT_SECRET=your-entra-client-secret
MICROSOFT_MPN_ID=your-microsoft-partner-network-id

# ── Azure Key Vault (optional — for hybrid Azure+Vercel deployments) ──────────
AZURE_KEY_VAULT_URI=https://kv-virilocity-prod.vault.azure.net
AZURE_USE_MANAGED_IDENTITY=true

# ── NextAuth v5 ───────────────────────────────────────────────────────────────
AUTH_SECRET=your-nextauth-secret-min-32-chars
AUTH_URL=https://app.virilocity.io

# ── Vercel (CI/CD) ────────────────────────────────────────────────────────────
# Set in GitHub Secrets — not in .env
# VERCEL_TOKEN=...
# VERCEL_ORG_ID=...
# VERCEL_PROJECT_ID=...
# VERCEL_PROD_URL=https://virilocity.vercel.app

# ── Multicloud: Azure Container Apps (hybrid self-hosted) ─────────────────────
# Only needed for Docker/ACA deployments alongside Vercel
AZURE_CONTAINER_REGISTRY=virilocityacr.azurecr.io
AZURE_RESOURCE_GROUP=rg-virilocity-prod
AZURE_CONTAINER_APP=ca-virilocity-prod
